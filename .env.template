# Polymarket Bot - Credentials Template
# Copy this to .env and fill in your values.
# NEVER commit .env to git. NEVER share these values.

# Your MetaMask / Magic.link wallet private key (hex, starts with 0x)
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your Polymarket proxy wallet address (from polymarket.com/settings)
# This is DIFFERENT from your MetaMask address.
POLYMARKET_FUNDER=0xYOUR_PROXY_WALLET_ADDRESS_HERE
